# Discord
DISCORD_TOKEN=your-bot-token-here
GUILD_ID=000000000000000000

# Logging
LOG_LEVEL=INFO

# Postgres (consumed by the db service in docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=heyspace

# Async SQLAlchemy URL. In Docker the host is the compose service name `db`.
# For local runs against localhost use: postgresql+asyncpg://postgres:postgres@localhost:5432/heyspace
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/heyspace
